# .htaccess - Tối ưu SEO và redirect
RewriteEngine On

# Chuyển hướng www sang non-www
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Đảm bảo robots.txt và sitemap.xml có thể truy cập
<Files "robots.txt">
    Order Allow,Deny
    Allow from all
</Files>

<Files "sitemap.xml">
    Order Allow,Deny
    Allow from all
</Files>

# Cache cho SEO
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/xml "access plus 1 hour"
</IfModule>